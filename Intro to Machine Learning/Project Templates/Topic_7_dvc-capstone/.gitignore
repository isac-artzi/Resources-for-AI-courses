# Python
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/

# The SQLite database is BUILT from the raw CSVs by db/build_sqlite.py.
# It is a generated artifact, so we do not commit it. Run the build script
# once after cloning (the Streamlit app also builds it automatically).
db/*.sqlite

# Derived CSVs are regenerated by the app. Keep the folder (via .gitkeep)
# but ignore the generated files themselves.
data/derived/*.csv

# Pipeline artifacts produced by the DVC train stage.
data/derived/metrics.json
models/*.joblib

# DVC internals (created by `dvc init` / `dvc repro`).
/.dvc/cache
/.dvc/tmp

# OS / editor noise
.DS_Store
.vscode/
